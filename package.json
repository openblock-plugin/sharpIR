{
  "name": "sharp-ir",
  "version": "1.0.0",
  "author": "ArthurZheng",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openblock-plugin/sharpIR.git"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "npx openblock-registry-cli dev",
    "build": "npx openblock-registry-cli build",
    "build:obfuscate": "npx openblock-registry-cli build --obfuscate",
    "publish": "npx openblock-registry-cli publish",
    "publish:dry": "npx openblock-registry-cli publish --dry-run",
    "validate": "npx openblock-registry-cli validate",
    "i18n:update": "npx openblock-registry-cli i18n update",
    "lint": "eslint . --ext .js --fix"
  },
  "openblock": {
    "name": {
      "formatMessage": {
        "id": "sharpIR.name",
        "default": "Sharp IR Sensor"
      }
    },
    "extensionId": "sharpIR",
    "supportDevice": [
      "arduinoUno",
      "arduinoNano",
      "arduinoLeonardo",
      "arduinoMega2560",
      "arduinoEsp8266"
    ],
    "iconURL": "./assets/sharpIR.png",
    "description": {
      "formatMessage": {
        "id": "sharpIR.description",
        "default": "Infrared distance sensor based on the principle of triangle ranging."
      }
    },
    "msg": "./src/msg.json",
    "blocks": "./src/blocks.js",
    "toolbox": "./src/toolbox.js",
    "generator": "./src/generator.js",
    "translations": "./src/translations.js",
    "libraries": "./libraries",
    "tags": [
      "sensor"
    ],
    "helpLink": "https://wiki.openblock.cc"
  },
  "devDependencies": {
    "babel-eslint": "^10.0.1",
    "eslint": "^5.3.0",
    "eslint-config-scratch": "^5.0.0",
    "husky": "^9.0.0"
  }
}
